{
  "manifest_version": 3,
  "name": "PXLBLZ-IDE Controller Helper",
  "version": "1.0.0",
  "minimum_chrome_version": "127",
  "description": "Connects the PXLBLZ-IDE web app to Pixelblaze controllers on your local network. It relays the controller's WebSocket traffic.",
  "homepage_url": "https://jon-whiteroomsoftware.github.io/PXLBLZ-IDE/",
  "author": "White Room Software",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": { "service_worker": "background.js" },
  "action": {
    "default_title": "PXLBLZ-IDE Controller Helper",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://jon-whiteroomsoftware.github.io/PXLBLZ-IDE/*",
        "http://localhost:5174/*",
        "http://127.0.0.1:5174/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "permissions": ["offscreen"],
  "host_permissions": ["https://discover.electromage.com/*"],
  "optional_host_permissions": ["http://*/*", "ws://*/*"],
  "sandbox": {
    "pages": ["sandbox.html"]
  },
  "content_security_policy": {
    "sandbox": "sandbox allow-scripts; script-src 'self' 'unsafe-eval'; child-src 'none';"
  }
}
